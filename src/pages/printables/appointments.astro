import BaseLayout from "../../layouts/BaseLayout.astro";
import { siteTitle } from "../../data/site";

const rows = Array.from({ length: 6 });
---

<BaseLayout
  title={`${siteTitle} | Appointment Log`}
  description="Printable appointment log for questions, medication changes, tests, and next steps."
  currentPath="/printables/appointments"
  theme="resources"
>
  <section class="section-block shell printable-shell" data-reveal>
    <div class="print-sheet surface-card">
      <div class="print-sheet__header">
        <div>
          <p class="eyebrow">Printable tracker</p>
          <h1>Appointment Log</h1>
        </div>
        <button
          class="button button--primary print-only-button"
          type="button"
          data-print-page
        >
          Print this page
        </button>
      </div>

      <table class="tracker-table tracker-table--wide">
        <thead>
          <tr>
            <th>Date / Provider</th>
            <th>My Questions &amp; Concerns</th>
            <th>Medication Changes</th>
            <th>Tests &amp; Next Steps</th>
          </tr>
        </thead>
        <tbody>
          {
            rows.map(() => (
              <tr>
                <td>&nbsp;</td>
                <td>&nbsp;</td>
                <td>&nbsp;</td>
                <td>&nbsp;</td>
              </tr>
            ))
          }
        </tbody>
      </table>
    </div>
  </section>
</BaseLayout>
